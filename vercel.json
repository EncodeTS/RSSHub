{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "hono",
    "outputDirectory": "src",
    "rewrites": [
        {
            "source": "/favicon.ico",
            "destination": "/favicon.png"
        }
    ],
    "git": {
        "deploymentEnabled": {
            "gh-pages": false
        }
    },
    "github": {
        "silent": true
    }
}
